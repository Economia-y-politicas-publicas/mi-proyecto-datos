        "#| label: setup-owd\n",
        "#| include: false\n",
        "\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "df_owd = pd.read_csv(\n",
        "    \"https://ourworldindata.org/grapher/government-spending-vs-gdp-per-capita.csv?v=1&csvType=full&useColumnShortNames=true\",\n",
        "    storage_options={'User-Agent': 'Our World In Data data fetch/1.0'}\n",
        ")\n",
        "\n",
        "col_entity = \"entity\"\n",
        "col_year = \"year\"\n",
        "col_gdp = \"gdp_per_capita\"\n",
        "col_spending = \"expenditure\"\n",
        "col_pop = \"population_historical\"\n",
        "col_continent = \"owid_region\""
      ],
      "id": "setup-owd",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: animacion-gasto-pib\n",
        "\n",
        "df_anim = df_owd.dropna(subset=[col_gdp, col_spending, col_year, col_continent]).copy()\n",
        "df_anim = df_anim[(df_anim[col_spending] >= 0) & (df_anim[col_spending] <= 100)]\n",
        "df_anim[col_pop] = df_anim[col_pop].fillna(df_anim[col_pop].median())\n",
        "\n",
        "# Orden de regiones igual al de OWID (de la leyenda original)\n",
        "regiones = [\"North America\", \"South America\", \"Africa\", \"Europe\", \"Asia\", \"Oceania\"]\n",
        "años = sorted(df_anim[col_year].unique())\n",
        "\n",
        "# Filas fantasma para mantener las 6 trazas activas en toda la animación\n",
        "combinaciones_existentes = set(zip(df_anim[col_year], df_anim[col_continent]))\n",
        "filas_fantasma = []\n",
        "gdp_medio = df_anim[col_gdp].median()\n",
        "spending_medio = df_anim[col_spending].median()\n",
        "\n",
        "for año in años:\n",
        "    for region in regiones:\n",
        "        if (año, region) not in combinaciones_existentes:\n",
        "            filas_fantasma.append({\n",
        "                col_year: año, col_continent: region,\n",
        "                col_entity: f\"__placeholder_{region}\",\n",
        "                col_gdp: gdp_medio, col_spending: spending_medio,\n",
        "                col_pop: 0,\n",
        "            })\n",
        "\n",
        "df_fantasma = pd.DataFrame(filas_fantasma)\n",
        "df_anim_completo = pd.concat([df_anim, df_fantasma], ignore_index=True).sort_values(col_year)\n",
        "\n",
        "# Paleta calcada de los colores de OWID\n",
        "color_map = {\n",
        "    \"North America\": \"#e07b54\",   # salmón/naranja\n",
        "    \"South America\": \"#7d3f55\",   # vino/burdeos\n",
        "    \"Africa\":        \"#9a5fb3\",   # morado\n",
        "    \"Europe\":        \"#4c6a9c\",   # azul grisáceo\n",
        "    \"Asia\":          \"#1f9e89\",   # verde teal\n",
        "    \"Oceania\":       \"#5fc2c9\",   # celeste/cyan\n",
        "}\n",
        "\n",
        "fig = px.scatter(\n",
        "    df_anim_completo,\n",
        "    x=col_gdp,\n",
        "    y=col_spending,\n",
        "    animation_frame=col_year,\n",
        "    animation_group=col_entity,\n",
        "    size=col_pop,\n",
        "    color=col_continent,\n",
        "    color_discrete_map=color_map,\n",
        "    category_orders={col_continent: regiones},\n",
        "    hover_name=col_entity,\n",
        "    log_x=True,\n",
        "    size_max=60,\n",
        "    range_x=[df_anim[col_gdp].min() * 0.8, df_anim[col_gdp].max() * 1.2],\n",
        "    range_y=[0, 60],\n",
        "    template=\"plotly_white\",\n",
        "    labels={\n",
        "        col_gdp: \"PIB per cápita (US$, escala log)\",\n",
        "        col_spending: \"Gasto de gobierno (% del PIB)\",\n",
        "        col_year: \"Año\",\n",
        "        col_continent: \"Región\",\n",
        "    },\n",
        ")\n",
        "\n",
        "# Tipografía y título estilo OWID (serif para título, sans para el resto)\n",
        "fig.update_layout(\n",
        "    title=dict(\n",
        "        text=\"<b>Gasto público como % del PIB vs. PIB per cápita</b>\"\n",
        "             \"<br><span style='font-size:13px; color:gray; font-family:Inter'>\"\n",
        "             \"Gasto total del gobierno como porcentaje del PIB. El PIB per cápita está \"\n",
        "             \"ajustado por inflación y diferencias en costo de vida entre países.</span>\",\n",
        "        font=dict(family=\"Georgia, serif\", size=22, color=\"#222\"),\n",
        "        x=0.02, xanchor=\"left\",\n",
        "    ),\n",
        "    font=dict(family=\"Inter, Arial\", size=13, color=\"#333\"),\n",
        "    legend=dict(\n",
        "        title=dict(text=\"<b>Región</b>\", font=dict(size=13)),\n",
        "        orientation=\"v\", x=1.02, y=1, xanchor=\"left\",\n",
        "        bgcolor=\"rgba(0,0,0,0)\",\n",
        "    ),\n",
        "    plot_bgcolor=\"white\",\n",
        "    paper_bgcolor=\"white\",\n",
        "    height=620,\n",
        "    margin=dict(t=110, b=90, l=70, r=160),\n",
        ")\n",
        "\n",
        "# Formato de ejes tipo OWID: $ en X (log), % en Y\n",
        "fig.update_xaxes(\n",
        "    tickprefix=\"$\", separatethousands=True,\n",
        "    showgrid=True, gridcolor=\"#e8e8e8\",\n",
        "    title_font=dict(size=14),\n",
        "    tickfont=dict(size=12),\n",
        ")\n",
        "fig.update_yaxes(\n",
        "    ticksuffix=\"%\",\n",
        "    showgrid=True, gridcolor=\"#e8e8e8\",\n",
        "    zeroline=True, zerolinecolor=\"#ccc\",\n",
        "    title_font=dict(size=14),\n",
        "    tickfont=dict(size=12),\n",
        ")\n",
        "\n",
        "# Estilo de los puntos: borde sutil como en OWID\n",
        "fig.update_traces(\n",
        "    marker=dict(line=dict(width=0.5, color=\"white\"), opacity=0.85),\n",
        "    selector=dict(mode=\"markers\"),\n",
        ")\n",
        "\n",
        "agregar_autor(fig)\n",
        "fig.show()"
      ],
      "id": "animacion-gasto-pib",
      "execution_count": null,
      "outputs": []
    }
