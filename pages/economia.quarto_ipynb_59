        "#| label: setup-owd\n",
        "#| include: false\n",
        "\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "df_owd = pd.read_csv(\n",
        "    \"https://ourworldindata.org/grapher/government-spending-vs-gdp-per-capita.csv?v=1&csvType=full&useColumnShortNames=true\",\n",
        "    storage_options={'User-Agent': 'Our World In Data data fetch/1.0'}\n",
        ")\n",
        "\n",
        "col_entity = \"entity\"\n",
        "col_year = \"year\"\n",
        "col_gdp = \"gdp_per_capita\"\n",
        "col_spending = \"expenditure\"\n",
        "col_pop = \"population_historical\"\n",
        "col_continent = \"owid_region\""
      ],
      "id": "setup-owd",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: animacion-gasto-pib\n",
        "\n",
        "import numpy as np\n",
        "import plotly.graph_objects as go\n",
        "\n",
        "df_anim = df_owd.dropna(subset=[col_gdp, col_spending, col_year, col_continent]).copy()\n",
        "df_anim = df_anim[(df_anim[col_spending] >= 0) & (df_anim[col_spending] <= 100)]\n",
        "df_anim[col_pop] = df_anim[col_pop].fillna(df_anim[col_pop].median())\n",
        "df_anim = df_anim[df_anim[col_year] >= 1925]\n",
        "\n",
        "regiones = [\"North America\", \"South America\", \"Africa\", \"Europe\", \"Asia\", \"Oceania\"]\n",
        "años = sorted(df_anim[col_year].unique())\n",
        "\n",
        "combinaciones_existentes = set(zip(df_anim[col_year], df_anim[col_continent]))\n",
        "filas_fantasma = []\n",
        "gdp_medio = df_anim[col_gdp].median()\n",
        "spending_medio = df_anim[col_spending].median()\n",
        "\n",
        "for año in años:\n",
        "    for region in regiones:\n",
        "        if (año, region) not in combinaciones_existentes:\n",
        "            filas_fantasma.append({\n",
        "                col_year: año, col_continent: region,\n",
        "                col_entity: f\"__placeholder_{region}\",\n",
        "                col_gdp: gdp_medio, col_spending: spending_medio,\n",
        "                col_pop: 0,\n",
        "            })\n",
        "\n",
        "df_fantasma = pd.DataFrame(filas_fantasma)\n",
        "df_anim_completo = pd.concat([df_anim, df_fantasma], ignore_index=True).sort_values(col_year)\n",
        "df_anim_completo[\"etiqueta\"] = df_anim_completo[col_entity].apply(\n",
        "    lambda x: \"\" if str(x).startswith(\"__placeholder_\") else x\n",
        ")\n",
        "\n",
        "color_map = {\n",
        "    \"North America\": \"#e07b54\",\n",
        "    \"South America\": \"#7d3f55\",\n",
        "    \"Africa\":        \"#9a5fb3\",\n",
        "    \"Europe\":        \"#4c6a9c\",\n",
        "    \"Asia\":          \"#1f9e89\",\n",
        "    \"Oceania\":       \"#5fc2c9\",\n",
        "}\n",
        "\n",
        "# --- Gráfico base (sin tendencia todavía) ---\n",
        "fig = px.scatter(\n",
        "    df_anim_completo,\n",
        "    x=col_gdp,\n",
        "    y=col_spending,\n",
        "    animation_frame=col_year,\n",
        "    animation_group=col_entity,\n",
        "    size=col_pop,\n",
        "    color=col_continent,\n",
        "    color_discrete_map=color_map,\n",
        "    category_orders={col_continent: regiones},\n",
        "    hover_name=col_entity,\n",
        "    text=\"etiqueta\",\n",
        "    log_x=True,\n",
        "    size_max=60,\n",
        "    range_x=[df_anim[col_gdp].min() * 0.8, df_anim[col_gdp].max() * 1.2],\n",
        "    range_y=[0, 60],\n",
        "    template=\"plotly_white\",\n",
        "    labels={\n",
        "        col_gdp: \"PIB per cápita (US$, escala log)\",\n",
        "        col_spending: \"Gasto de gobierno (% del PIB)\",\n",
        "        col_year: \"Año\",\n",
        "        col_continent: \"Región\",\n",
        "    },\n",
        ")\n",
        "\n",
        "fig.update_traces(\n",
        "    textposition=\"top center\",\n",
        "    textfont=dict(size=9, color=\"#444\"),\n",
        "    marker=dict(line=dict(width=0.5, color=\"white\"), opacity=0.85),\n",
        "    selector=dict(mode=\"markers+text\"),\n",
        ")\n",
        "\n",
        "# --- Función para calcular regresión de un año específico ---\n",
        "def calcular_tendencia(año):\n",
        "    datos_año = df_anim[df_anim[col_year] == año]\n",
        "    if len(datos_año) < 3:\n",
        "        return None, None, None\n",
        "    log_gdp = np.log10(datos_año[col_gdp])\n",
        "    pendiente, intercepto = np.polyfit(log_gdp, datos_año[col_spending], 1)\n",
        "    x_línea = np.linspace(df_anim[col_gdp].min(), df_anim[col_gdp].max(), 50)\n",
        "    y_línea = pendiente * np.log10(x_línea) + intercepto\n",
        "    return pendiente, x_línea, y_línea\n",
        "\n",
        "# --- Traza inicial de tendencia (para el primer año del slider) ---\n",
        "pendiente_inicial, x0, y0 = calcular_tendencia(años[0])\n",
        "if pendiente_inicial is None:\n",
        "    x0, y0, pendiente_inicial = [df_anim[col_gdp].min()], [spending_medio], 0\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(\n",
        "        x=x0, y=y0, mode=\"lines\",\n",
        "        line=dict(color=\"black\", width=2, dash=\"dash\"),\n",
        "        name=f\"Tendencia ({pendiente_inicial:.2f})\",\n",
        "        showlegend=True,\n",
        "    )\n",
        ")\n",
        "\n",
        "# --- Actualizar cada frame: agregar su propia línea de tendencia y anotación ---\n",
        "for frame in fig.frames:\n",
        "    año_frame = int(frame.name)\n",
        "    pendiente, x_línea, y_línea = calcular_tendencia(año_frame)\n",
        "    if pendiente is None:\n",
        "        x_línea, y_línea, pendiente = [df_anim[col_gdp].min()], [spending_medio], 0\n",
        "\n",
        "    nueva_traza = go.Scatter(\n",
        "        x=x_línea, y=y_línea, mode=\"lines\",\n",
        "        line=dict(color=\"black\", width=2, dash=\"dash\"),\n",
        "        name=f\"Tendencia ({pendiente:.2f})\",\n",
        "        showlegend=True,\n",
        "    )\n",
        "    frame.data = list(frame.data) + [nueva_traza]\n",
        "    frame.layout = go.Layout(\n",
        "        annotations=[dict(\n",
        "            text=f\"Pendiente {año_frame}: cada aumento de 10x en el PIB per cápita se asocia \"\n",
        "                 f\"a un cambio de <b>{pendiente:.2f} puntos porcentuales</b> en el gasto público\",\n",
        "            x=0, y=1.10, xref=\"paper\", yref=\"paper\",\n",
        "            showarrow=False, font=dict(size=12, color=\"#555\"), xanchor=\"left\",\n",
        "        )]\n",
        "    )\n",
        "\n",
        "fig.update_layout(\n",
        "    title=dict(\n",
        "        text=\"<b>Gasto público vs. PIB per cápita en el mundo</b>\",\n",
        "        font=dict(family=\"Georgia, serif\", size=22, color=\"#222\"),\n",
        "        x=0.02, xanchor=\"left\", y=0.97,\n",
        "    ),\n",
        "    annotations=[\n",
        "        dict(\n",
        "            text=\"Evolución histórica del gasto del gobierno como % del PIB, frente al PIB per cápita<br>\"\n",
        "                 \"ajustado por inflación y costo de vida, por país y región (1925–2024).\",\n",
        "            x=0, y=1.16, xref=\"paper\", yref=\"paper\",\n",
        "            showarrow=False, font=dict(size=13, color=\"gray\", family=\"Inter\"),\n",
        "            xanchor=\"left\", align=\"left\",\n",
        "        ),\n",
        "        dict(\n",
        "            text=f\"Pendiente {años[0]}: cada aumento de 10x en el PIB per cápita se asocia \"\n",
        "                 f\"a un cambio de <b>{pendiente_inicial:.2f} puntos porcentuales</b> en el gasto público\",\n",
        "            x=0, y=1.06, xref=\"paper\", yref=\"paper\",\n",
        "            showarrow=False, font=dict(size=12, color=\"#555\"), xanchor=\"left\",\n",
        "        ),\n",
        "    ],\n",
        "    font=dict(family=\"Inter, Arial\", size=13, color=\"#333\"),\n",
        "    legend=dict(\n",
        "        title=dict(text=\"<b>Región</b>\", font=dict(size=13)),\n",
        "        orientation=\"v\", x=1.02, y=0.85, xanchor=\"left\",\n",
        "        bgcolor=\"rgba(0,0,0,0)\",\n",
        "    ),\n",
        "    plot_bgcolor=\"white\",\n",
        "    paper_bgcolor=\"white\",\n",
        "    height=820,\n",
        "    margin=dict(t=200, b=230, l=70, r=200),\n",
        ")\n",
        "\n",
        "fig.update_xaxes(\n",
        "    tickprefix=\"$\", separatethousands=True,\n",
        "    showgrid=True, gridcolor=\"#e8e8e8\",\n",
        "    title_font=dict(size=14), tickfont=dict(size=12),\n",
        ")\n",
        "fig.update_yaxes(\n",
        "    ticksuffix=\"%\",\n",
        "    showgrid=True, gridcolor=\"#e8e8e8\",\n",
        "    zeroline=True, zerolinecolor=\"#ccc\",\n",
        "    title_font=dict(size=14), tickfont=dict(size=12),\n",
        ")\n",
        "\n",
        "# IMPORTANTE: ahora cada frame también debe llevar AMBAS anotaciones (subtítulo fijo + pendiente dinámica),\n",
        "# porque al cambiar de año, Plotly reemplaza TODAS las anotaciones del frame, no solo la de pendiente.\n",
        "subtítulo_fijo = dict(\n",
        "    text=\"Evolución histórica del gasto del gobierno como % del PIB, frente al PIB per cápita<br>\"\n",
        "         \"ajustado por inflación y costo de vida, por país y región (1925–2024).\",\n",
        "    x=0, y=1.16, xref=\"paper\", yref=\"paper\",\n",
        "    showarrow=False, font=dict(size=13, color=\"gray\", family=\"Inter\"),\n",
        "    xanchor=\"left\", align=\"left\",\n",
        ")\n",
        "\n",
        "for frame in fig.frames:\n",
        "    pendiente_anotacion = frame.layout.annotations[0] if frame.layout.annotations else None\n",
        "    if pendiente_anotacion is not None:\n",
        "        pendiente_anotacion = dict(pendiente_anotacion.to_plotly_json())\n",
        "        pendiente_anotacion[\"y\"] = 1.06\n",
        "        frame.layout = go.Layout(annotations=[subtítulo_fijo, pendiente_anotacion])\n",
        "\n",
        "# Empujar el slider y los botones de play/pause bien abajo del gráfico\n",
        "slider_actual = fig.layout.sliders[0].to_plotly_json()\n",
        "slider_actual[\"y\"] = -0.22\n",
        "slider_actual[\"pad\"] = dict(t=30)\n",
        "\n",
        "updatemenu_actual = fig.layout.updatemenus[0].to_plotly_json()\n",
        "updatemenu_actual[\"y\"] = -0.08\n",
        "\n",
        "fig.update_layout(\n",
        "    sliders=[slider_actual],\n",
        "    updatemenus=[updatemenu_actual],\n",
        ")\n",
        "\n",
        "# Nota de autor + fuentes, bien abajo, después del slider\n",
        "fig.update_layout(\n",
        "    annotations=list(fig.layout.annotations) + [dict(\n",
        "        text=\"Autor: Juan Miguieles Onetto<br>\"\n",
        "             \"Fuentes: International Monetary Fund (2025) · \"\n",
        "             \"Bolt and van Zanden – Maddison Project Database (2023) · HYDE (2023) · \"\n",
        "             \"Gapminder, Population v7 (2022) · UN, World Population Prospects (2024) · \"\n",
        "             \"Gapminder – Systema Globalis (2022)<br>\"\n",
