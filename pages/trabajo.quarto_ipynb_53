    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "series_vacantes = {\n",
        "    \"Antofagasta\": \"F049.VTR.IND.BCC1.61.M\",\n",
        "    \"Valparaíso\":  \"F049.VTR.IND.BCC1.62.M\",\n",
        "    \"Concepción\":  \"F049.VTR.IND.BCC1.63.M\",\n",
        "    \"Temuco\":      \"F049.VTR.IND.BCC1.64.M\",\n",
        "    \"Santiago\":    \"F049.VTR.IND.BCC1.65.M\",\n",
        "    \"Total\":       \"F049.VTR.IND.BCC1.01.M\",\n",
        "    \"Total ponderado\": \"F049.VTR.IND.BCC1.66.M\",\n",
        "}\n",
        "\n",
        "vacantes = {}\n",
