        "---\n",
        "title: \"Mercado Laboral\"\n",
        "subtitle: \"Empleo y desempleo en Chile\"\n",
        "date: last-modified\n",
        "---\n",
        "\n",
        "## Contexto\n",
        "\n",
        "El mercado laboral es uno de los indicadores más importantes del bienestar económico de un país. En Chile, el **Instituto Nacional de Estadísticas (INE)** publica mensualmente la **Encuesta Nacional de Empleo (ENE)**, que mide el estado laboral de la población a través de períodos móviles de tres meses."
      ],
      "id": "46c6837a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: setup\n",
        "#| include: false\n",
        "\n",
        "import os\n",
        "import requests\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "import plotly.graph_objects as go\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "# ── Datos CSV (tasa de desempleo) ─────────────────────────────────────────────\n",
        "dt = pd.read_csv(\"../data/trabajo.csv\", sep=\",\", encoding=\"utf-8\")\n",
        "dt = dt.rename(columns={\n",
        "    \"Tiempo\": \"periodo\", \"Año\": \"año\", \"Mes\": \"mes\",\n",
        "    \"Total\": \"total\", \"Hombre\": \"hombre\", \"Mujer\": \"mujer\"\n",
        "})\n",
        "dt[[\"año\",\"mes\",\"total\",\"hombre\",\"mujer\"]] = dt[[\"año\",\"mes\",\"total\",\"hombre\",\"mujer\"]].apply(pd.to_numeric, errors=\"coerce\")\n",
        "dt = dt.dropna(subset=[\"año\",\"mes\",\"total\"])\n",
        "dt = dt[(dt[\"año\"] >= 2010) & (dt[\"año\"] <= 2030)]\n",
        "dt[\"fecha\"] = pd.to_datetime(dict(year=dt[\"año\"], month=dt[\"mes\"], day=1))\n",
        "dt = dt.sort_values(\"fecha\").reset_index(drop=True)\n",
        "dt[\"brecha\"] = dt[\"mujer\"] - dt[\"hombre\"]\n",
        "\n",
        "# ── API Banco Central (fuerza de trabajo) ──────────────────────────────────────\n",
        "usuario  = os.environ.get(\"BCENTRAL_USER\")\n",
        "password = os.environ.get(\"BCENTRAL_PASS\")\n",
        "URL_API  = \"https://si3.bcentral.cl/SieteRestWS/SieteRestWS.ashx\"\n",
        "\n",
        "def obtener_serie(codigo, dias=1095):\n",
        "    hoy    = datetime.today()\n",
        "    inicio = (hoy - timedelta(days=dias)).strftime(\"%Y-%m-%d\")\n",
        "    fin    = hoy.strftime(\"%Y-%m-%d\")\n",
        "    params = {\n",
        "        \"user\": usuario, \"pass\": password,\n",
        "        \"function\": \"GetSeries\", \"timeseries\": codigo,\n",
        "        \"firstdate\": inicio, \"lastdate\": fin, \"format\": \"json\",\n",
        "    }\n",
        "    try:\n",
        "        r   = requests.get(URL_API, params=params, timeout=10)\n",
        "        data = r.json()\n",
        "        obs  = data[\"Series\"][\"Obs\"]\n",
        "        df   = pd.DataFrame(obs)\n",
        "        col_fecha = \"indexDateString\" if \"indexDateString\" in df.columns else df.columns[0]\n",
        "        col_valor = \"value\" if \"value\" in df.columns else df.columns[1]\n",
        "        df[\"fecha\"] = pd.to_datetime(df[col_fecha], format=\"%d-%m-%Y\", errors=\"coerce\")\n",
        "        df[\"valor\"] = pd.to_numeric(df[col_valor], errors=\"coerce\")\n",
        "        return df.dropna(subset=[\"valor\"]).sort_values(\"fecha\").reset_index(drop=True)\n",
        "    except Exception as e:\n",
        "        print(f\"Error cargando {codigo}: {e}\")\n",
        "        return pd.DataFrame(columns=[\"fecha\", \"valor\"])\n",
        "\n",
        "def grafico_linea(df, titulo, ytitle, color, formato_y=\".2f\", prefijo=\"\", sufijo=\"\"):\n",
        "    if df.empty:\n",
        "        return go.Figure()\n",
        "    ultimo = df[\"valor\"].iloc[-1]\n",
        "    fecha  = df[\"fecha\"].iloc[-1].strftime(\"%d/%m/%Y\")\n",
        "    minimo = df[\"valor\"].min()\n",
        "    maximo = df[\"valor\"].max()\n",
        "    margen = (maximo - minimo) * 0.05\n",
        "    fig = go.Figure()\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=df[\"fecha\"], y=df[\"valor\"],\n",
        "        mode=\"lines\",\n",
        "        line=dict(color=color, width=2),\n",
        "        fill=\"tozeroy\",\n",
        "        fillcolor=color.replace(\")\", \",0.1)\").replace(\"rgb\", \"rgba\"),\n",
        "        hovertemplate=f\"<b>%{{x|%d %b %Y}}</b><br>{prefijo}%{{y:{formato_y}}}{sufijo}<extra></extra>\",\n",
        "    ))\n",
        "    fig.update_layout(\n",
        "        title=dict(text=f\"{titulo} — Último: {prefijo}{ultimo:{formato_y}}{sufijo} ({fecha})\", font=dict(size=15)),\n",
        "        yaxis=dict(title=ytitle, tickformat=formato_y, tickprefix=prefijo, ticksuffix=sufijo, range=[minimo - margen, maximo + margen]),\n",
        "        xaxis=dict(dtick=\"M6\", tickformat=\"%b %Y\", tickangle=45, tickfont=dict(size=10)),\n",
        "        template=\"plotly_white\",\n",
        "        font_family=\"Inter\",\n",
        "        height=400,\n",
        "        margin=dict(b=100, t=60),\n",
        "        annotations=[dict(\n",
        "            text=\"Autor: Juan Miguieles Onetto | Fuente: INE / Banco Central de Chile\",\n",
        "            x=0, y=-0.3, xref=\"paper\", yref=\"paper\",\n",
        "            showarrow=False, font=dict(size=10, color=\"gray\"), xanchor=\"left\",\n",
        "        )],\n",
        "    )\n",
        "    return fig\n",
        "\n",
        "# Cargar series API\n",
        "pob15mas    = obtener_serie(\"F049.POB.PMT.INE9.01.M\")\n",
        "ftt         = obtener_serie(\"F049.FTR.PMT.INE9.01.M\")\n",
        "ocupados    = obtener_serie(\"F049.OCU.PMT.INE9.01.M\")\n",
        "desocupados = obtener_serie(\"F049.DES.PMT.INE9.01.M\")\n",
        "cesantes    = obtener_serie(\"F049.CES.PMT.INE9.01.M\")\n",
        "btpv        = obtener_serie(\"F049.BPV.PMT.INE9.01.M\")\n",
        "inactivos   = obtener_serie(\"F049.INC.PMT.INE9.01.M\")\n",
        "\n",
        "\n",
        "ivtantofagasta    = obtener_serie(\"F049.VTR.IND.BCC1.61.M\")\n",
        "ivtvalpo         = obtener_serie(\"F049.VTR.IND.BCC1.62.M\")\n",
        "ivtconce    = obtener_serie(\"F049.VTR.IND.BCC1.63.M\")\n",
        "ivttemuco = obtener_serie(\"F049.VTR.IND.BCC1.64.M\")\n",
        "ivtsantiago   = obtener_serie(\"F049.VTR.IND.BCC1.65.M\")\n",
        "ivttotal       = obtener_serie(\"F049.VTR.IND.BCC1.01.M\")\n",
        "ivttotalponderado   = obtener_serie(\"F049.VTR.IND.BCC1.66.M\")\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "AUTOR = \"Autor: Juan Miguieles Onetto | Fuente: INE\"\n",
        "NOTA  = \"Nota: La tasa de desempleo se mide trimestralmente mediante la ENE.\"\n",
        "\n",
        "def agregar_autor(fig):\n",
        "    fig.update_layout(\n",
        "        annotations=[\n",
        "            dict(text=AUTOR, x=0, y=-0.18, xref=\"paper\", yref=\"paper\",\n",
        "                 showarrow=False, font=dict(size=10, color=\"gray\"), xanchor=\"left\"),\n",
        "            dict(text=NOTA,  x=0, y=-0.24, xref=\"paper\", yref=\"paper\",\n",
        "                 showarrow=False, font=dict(size=9, color=\"#aaaaaa\"), xanchor=\"left\"),\n",
        "        ]\n",
        "    )\n",
        "    return fig\n",
        "\n",
        "eje_x = dict(dtick=\"M6\", tickformat=\"%b %Y\", tickangle=45, tickfont=dict(size=10))"
      ],
      "id": "setup",
      "execution_count": null,
      "outputs": []
    },
