    "#| label: animacion-gasto-pib\n",
    "\n",
    "# Filtrar filas con datos completos para que la animación no salte\n",
    "df_anim = df_owd.dropna(subset=[col_gdp, col_spending, col_year]).copy()\n",
    "\n",
    "# Ordenar por año para que el slider se vea correcto\n",
    "df_anim = df_anim.sort_values(col_year)\n",
    "\n",
    "fig = px.scatter(\n",
    "    df_anim,\n",
    "    x=col_gdp,\n",
    "    y=col_spending,\n",
    "    animation_frame=col_year,\n",
    "    animation_group=col_entity,\n",
    "    size=col_pop,\n",
    "    color=col_continent,\n",
    "    hover_name=col_entity,\n",
    "    log_x=True,\n",
    "    size_max=55,\n",
    "    range_x=[df_anim[col_gdp].min() * 0.8, df_anim[col_gdp].max() * 1.2],\n",
    "    range_y=[df_anim[col_spending].min() * 0.8, df_anim[col_spending].max() * 1.2],\n",
    "    template=\"plotly_white\",\n",
    "    labels={\n",
    "        col_gdp: \"PIB per cápita (US$, log)\",\n",
    "        col_spending: \"Gasto de gobierno (% del PIB)\",\n",
    "        col_year: \"Año\",\n",
    "    },\n",
    ")\n",
    "\n",
    "fig.update_layout(\n",
    "    title=dict(text=\"Gasto público vs. PIB per cápita en el tiempo\", font=dict(size=18)),\n",
    "    font=dict(family=\"Inter\", size=14),\n",
    "    height=600,\n",
